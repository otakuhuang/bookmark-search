{
  "name": "Bookmark Search",
  "description": "通过对话分析收藏夹, 推荐合适的页面",
  "version": "1.0.0",
  "manifest_version": 3,
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "sandbox": {
    "pages": [
      "src/sandbox/sandbox.html"
    ]
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "models/**",
        "assets/worker.js",
        "src/popup/settings.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}